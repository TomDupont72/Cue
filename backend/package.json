{
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "test": "tsc --noEmit -p tsconfig.test.json && node --import tsx --test src/modules/*/__tests__/*.test.ts src/shared/utils/*/__tests__/*.test.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/cors": "^11.3.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^7.0.0",
    "globals": "^17.7.0",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prettier": "^3.9.6",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.0",
